    <item>
      <title>現代の女ってロールモデルに恵まれてないのかなって思う</title>
      <link>https://n-kase.github.io/rss/posts/post-275/</link>
      <pubDate>Tue, 16 Jun 2026 09:50:09 +0900</pubDate>
      
