			</tr>
	</thead>
	<tbody>
			<tr>
					<td>第1世代</td>
					<td>2022 - 2024</td>
					<td>Prompt Engineering</td>
					<td>1つの指示を磨き上げる</td>
					<td>指示の質</td>
			</tr>
			<tr>
					<td>第2世代</td>
					<td>2025</td>
