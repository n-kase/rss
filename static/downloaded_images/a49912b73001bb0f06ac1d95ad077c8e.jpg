                offlineDay,
                onlineYear,
                currentYear,
                offlineYear,
                onlineStoreInputForm,
                offlineStoreInputForm,
                enableOfflineStoreRadio,
                enableOnlineStoreRadio,
                onlineCalendar,
                offlineCalendar,
                offlineStateMain,
                offlineState,
                note1
            );
        }

    });
