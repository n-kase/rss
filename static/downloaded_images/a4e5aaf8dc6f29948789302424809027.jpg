            <span class="a-size-small a-color-tertiary">ギフトオプション</span> </div>
    </div>
  <div class="offer-display-feature-text a-size-small" offer-display-feature-name="desktop-dynamic-gift-wrap" data-csa-c-type="widget"
     data-csa-c-slot-id="odf-feature-text-desktop-dynamic-gift-wrap" data-csa-c-content-id="desktop-dynamic-gift-wrap">
