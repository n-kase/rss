ea0-e62a92316e8e" k-style="inlineStyles_235_5" k-class="mergedStyles_236_5" onclick><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z"><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IY0d __P0nNOOvpt01x __HcWluv-7J"><div data-testid="mentions-inline" style="" class="aui-primitive __HcW37uIi- __HcWIi-82IY0d"><span style="white-space: pre-line;" class="aui-primitive __HcWWkUdHN __HcWNg-FAv __3LVrZoFAv">51人のお客様がキャラクターデザインに言及し、45人が肯定的、6人が否定的です</span><span style="white-space: pre-line;" aria-hidden="true" class="aui-primitive __SAR2l0zNyyuZ"><span style="white-space: pre-line;" class="aui-primitive"><span style="white-space: pre-line;" class="aui-primitive __SAR2l0zNyyuZ">51人のお客様が「キャラクターデザイン」に言及しています</span></span></span><span style="white-space: pre-line;" aria-hidden="true" class="aui-primitive __dChWb2ruQw4B __P0nNOOzO001x __SAR2l0zNyyuZ">45肯定的</span><span style="white-space: pre-line;" aria-hidden="true" class="aui-primitive __dChF3jO2MCfBw4B __P0nNOOzO001x __SAR2l0zNyyuZ">6否定的</span></div><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWV4cGFuZCI6Il84Ml8yOSIsImstaWQiOiJhYmU5ZTljYi1lZmRkLTRlOTYtYmY5Zi1lMmVjM2I4MjEwZjEiLCJrLXBhcmVudCI6IjViYjkwZTNiLTBkZDEtNDljMi1iMzhkLWI0MWY0NzdiYTlkMyJ9 --><!-- k-injected k+b64  --><!-- k-injected k+b64  --><!-- k-injected k+b64  --><!-- k-injected k+b64  --><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWV4cGFuZC1sZXQiOiJhY2Nlc3NpYmlsaXR5U3RfMTE2XzExIiwiay1wYXJlbnQiOiJjYWZjOTZmYi0wMDdkLTQwM2ItYTI0ZS04YThmZTI0ZTk5MDciLCJrLWRhdGEiOnt9fQ== --><button k-on-click="isLongPress_onP_123_54" k-on-mousedown="isLongPress_onP_125_5" k-on-mouseup="onPressOut_onLo_126_5" aria-label="閉じる" data-testid="close-button" style="border: none; background-color: transparent; margin: 0; padding: 0; text-align: inherit; font: inherit; border-radius: 0; -webkit-tap-highlight-color: transparent;" class="aui-primitive __HcW37uIi- __HcWz_S8Xm" k-observe k-use="cafc96fb-007d-403b-a24e-8a8fe24e9907" k-aria-checked="tmpCoalesce_tmp_138_54" k-aria-pressed="tmpCoalesce_tmp_139_54" k-aria-selected="tmpCoalesce_tmp_140_55" k-aria-disabled="tmpCoalesce_tmp_141_55" k-style="inlineStyles_146_3" k-class="mergedStyles_147_3" onclick><img src="https://m.media-amazon.com/images/S/sash/FQQMS6xydSSApTa.png" k-metric-loaded-enabled="false" aria-hidden="true" style="display:inline-block;height:12px;width:12px;object-fit:cover;" class="aui-primitive __HcWIi-bS7X-z"/></button><!-- k-injected k-component-close --><!-- k-injected k-component-close --></div><span style="white-space: pre-line;" data-testid="aspect-summary" class="aui-primitive __P0nNOOvpt01x __SAR2l0zNyyuZ">お客様はこのゲームのキャラクターデザインを高く評価しています。男性キャラがよりかっこよく、女性キャラも可愛らしくなっていると感じています。3Dのキャラも良いと好評です。また、キャラクター同志の連携技や戦闘システム、テンポの良さなど、様々な楽しみ方を与えてくれるとの声があります。ストーリー進行やキャラクターとの連携技、高難易度の歯応え、BGMなどの要素も魅力的だと感じているようです。</span><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z __P0nNOOKHIwIJ"><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWNvbXBvbmVudCI6IlNuaXBwZXRMaXN0LXA3WW9hU2tvbnBtRVNMViIsImstaWQiOiJhNGM2NzBkMy0xZjdlLTQ4ZmEtOWU5Yy02YzIyYmMyNmY5N2IiLCJrLWNvbXBvc2VkIjoiU25pcHBldExpc3RfYXNwXzEwMF8yNSIsImstcGFyZW50IjoiNWJiOTBlM2ItMGRkMS00OWMyLWIzOGQtYjQxZjQ3N2JhOWQzIiwiay1kYXRhIjp7fX0= --><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z"><!-- k-injected k+b64  --><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z __P0nNOOvpt01x"><div data-csa-c-type="uxElement" data-csa-c-item-id="cr-product-insights-detail-page_read-more-link" data-csa-c-pos="" data-csa-c-posx="" data-csa-c-posy="" data-csa-c-owner="CustomerReviews" data-csa-c-item-type="" data-csa-c-parent-element-id="" class="aui-primitive" data-csa-c-slot-id="cr-product-insights-detail-page_read-more-link"><span style="white-space: pre-line;" class="aui-primitive __SAR2l0zNyyuZ"><span style="white-space: pre-line;" aria-hidden="true" class="aui-primitive __SAR2l0zNyyuZ">&quot;</span><span style="white-space: pre-line;" class="aui-primitive"><span style="white-space: pre-line;" class="aui-primitive __SAR2l0zNyyuZ">発売日に購入しクリアまで遊びました。 原作をリスペクトしつつ、現代に合わせた ゲームバランスと世界観、</span><span style="white-space: pre-line;" class="aui-primitive __SAR2l0zNyyuZ __SARCET4AB">キャラデザイン</span><span style="white-space: pre-line;" class="aui-primitive __SAR2l0zNyyuZ">(ここは賛否あるだろうが)に昇華されています。 ロードの長さは気になるが、ガチ勢でなければswitchで十分楽しめると思います。</span></span><span style="white-space: pre-line;" aria-hidden="true" class="aui-primitive __SAR2l0zNyyuZ">&quot;</span><span style="white-space: pre-line;" aria-hidden="true" class="aui-primitive"> </span><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWNvbXBvbmVudCI6IlRleHRMaW5rLXZHcGhSM0FHbzlwX0pHWiIsImstaWQiOiIzM2MyYjkzNS02YzQ0LTRlNjgtYTM2Zi02ZGVjOGY1YWQ5ODkiLCJrLWRhdGEiOnt9fQ== --><!-- k-injected k+b64  --><!-- k-injected k+b64  --><!-- k-injected k+b64  --><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWV4cGFuZC1sZXQiOiJ0YXJnZXRTdHJfNTZfNSIsImstcGFyZW50IjoiNGI3NGFhNGMtZWUxOC00MDJkLThmYTQtNzQxODg0NmUzZmY5Iiwiay1kYXRhIjp7InZhbHVlIjoiX3RvcCJ9fQ== --><!-- k-injected k+b64  --><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWV4cGFuZC1sZXQiOiJocmVmU3RyXzgxXzUiLCJrLXBhcmVudCI6IjRiNzRhYTRjLWVlMTgtNDAyZC04ZmE0LTc0MTg4NDZlM2ZmOSIsImstZGF0YSI6eyJ2YWx1ZSI6Ii9ncC9jdXN0b21lci1yZXZpZXdzL1IzSUhVNjRaSDJRTkhFIn19 --><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWV4cGFuZC1sZXQiOiJ1c2VIcmVmXzgyXzUiLCJrLXBhcmVudCI6IjRiNzRhYTRjLWVlMTgtNDAyZC04ZmE0LTc0MTg4NDZlM2ZmOSIsImstZGF0YSI6eyJ2YWx1ZSI6dHJ1ZX19 --><a href="/gp/customer-reviews/R3IHU64ZH2QNHE" target="_top" tabindex="0" data-testid="read-more" k-on-mousedown="pressed_onMouse_105_5" k-on-mouseup="pressed_onMouse_106_5" k-on-mouseenter="onMouseIn_107_32" k-on-mouseleave="onMouseOut_108_33" class="aui-primitive __SAR2l0zNyyuZ __SAR2l0N01yuZ" k-observe k-use="4b74aa4c-ee18-402d-8fa4-7418846e3ff9" k-class="mergedStyles_113_3" onclick><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWNvbXBvbmVudCI6IlRleHQtSENPUU52M001MW9lY0tfIiwiay1pZCI6IjNkNGJjMTk3LTE3OTYtNGFmZS1iM2NjLWYy