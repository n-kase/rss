isLongPress_onP_125_5" k-on-mouseup="onPressOut_onLo_126_5" aria-label="閉じる" data-testid="close-button" style="border: none; background-color: transparent; margin: 0; padding: 0; text-align: inherit; font: inherit; border-radius: 0; -webkit-tap-highlight-color: transparent;" class="aui-primitive __HcW37uIi- __HcWz_S8Xm" k-observe k-use="229c9a95-8384-4bce-b517-83cfb93ed49f" k-aria-checked="tmpCoalesce_tmp_138_54" k-aria-pressed="tmpCoalesce_tmp_139_54" k-aria-selected="tmpCoalesce_tmp_140_55" k-aria-disabled="tmpCoalesce_tmp_141_55" k-style="inlineStyles_146_3" k-class="mergedStyles_147_3" onclick><img src="https://m.media-amazon.com/images/S/sash/FQQMS6xydSSApTa.png" k-metric-loaded-enabled="false" aria-hidden="true" style="display:inline-block;height:12px;width:12px;object-fit:cover;" class="aui-primitive __HcWIi-bS7X-z"/></button><!-- k-injected k-component-close --><!-- k-injected k-component-close --></div><span style="white-space: pre-line;" data-testid="aspect-summary" class="aui-primitive __P0nNOOvpt01x __SAR2l0zNyyuZ">お客様はこのゲームを非常に面白く、初心者でも楽しめるゲームだと評価しています。オリジナルの面白さを失わずに、戦闘も楽しく、時間が溶けるという感覚が得られると好評です。また、オリジナルの魅力を存分に伝えており、キャラクターの個性や憎めない雰囲気が感じられるようです。</span><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z __P0nNOOKHIwIJ"><!-- k-injected k+b64 eyJrLW9ic2VydmUiOiIiLCJrLWNvbXBvbmVudCI6IlNuaXBwZXRMaXN0LXA3WW9hU2tvbnBtRVNMViIsImstaWQiOiJlYTQ5ZDBmOS1lMDhjLTRjNmMtOTdiNi00ZmU1ZGU1YjA1OTgiLCJrLWNvbXBvc2VkIjoiU25pcHBldExpc3RfYXNwXzEwMF8yNSIsImstcGFyZW50IjoiMTc2ZTAyZTItNTExNi00ODM5LWJmZWItOWFiNzM4ZmRhMjU2Iiwiay1kYXRhIjp7fX0= --><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z"><!-- k-injected k+b64  --><div style="" class="aui-primitive __HcW37uIi- __HcWIi-82IiB1 __HcWIi-bS7X-z __P0nNOOvpt01x"><div data-csa-c-type="uxElement" data-csa-c-item-id="cr-product-insights-detail-page_read-more-link" data-csa-c-pos="" data-csa-c-posx="" data-csa-c-posy="" data-csa-c-owner="CustomerReviews" data-csa-c-item-type="" data-csa-c