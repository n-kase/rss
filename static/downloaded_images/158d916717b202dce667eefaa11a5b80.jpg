            var cache = config.ewc.flyout.cache();
            cache.updateCacheAndEwcContainer("EWC_Cache_357-5727837-5726362__JPY_ja_JP", result);
                      
        }
        if (typeof window.uet === 'function') {
          window.uet('be', 'ewc', {wb: 1});
        }
      },
      complete: function() {
